<div class="max-w-4xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="page-title">Statistiques</h1>
    <% if (latestWeek) { %>
      <span class="font-mono text-xs text-ink-faint">Sem. <%= latestWeek.dates || latestWeek.week %></span>
    <% } %>
  </div>

  <% if (!latestWeek) { %>
    <div class="card p-10 text-center">
      <p class="text-ink-muted text-sm">Aucune donnée hebdomadaire disponible.</p>
      <p class="text-ink-faint text-xs mt-1">Les métriques apparaîtront après la première saisie.</p>
    </div>
  <% } else { %>

    <!-- 4 KPI cards -->
    <div class="grid grid-cols-2 gap-4 mb-6">
      <% var kpiData = [
        { label: "Taux d'engagement", value: kpis.engagementRate !== null ? kpis.engagementRate.toFixed(1) + '%' : '—', target: '> 5%' },
        { label: 'Taux INFO → DM', value: kpis.infoDmRate !== null ? kpis.infoDmRate + '%' : '—', target: '> 80%' },
        { label: 'Taux DM → Calendly', value: kpis.dmCalendlyRate !== null ? kpis.dmCalendlyRate + '%' : '—', target: '> 30%' },
        { label: 'Taux Calendly → Patient', value: kpis.calendlyPatientRate !== null ? kpis.calendlyPatientRate + '%' : '—', target: '> 70%' }
      ]; %>
      <% kpiData.forEach(function(k) { %>
        <div class="card p-5">
          <div class="text-xs text-ink-faint mb-2"><%= k.label %></div>
          <div class="stat-number"><%= k.value %></div>
          <div class="text-xs text-ink-faint mt-1.5">Cible <span class="text-ink-muted"><%= k.target %></span></div>
        </div>
      <% }); %>
    </div>

    <!-- Funnel -->
    <div class="card p-5 mb-6">
      <h2 class="section-title mb-4">Entonnoir d'acquisition</h2>
      <% if (funnelData.length === 0) { %>
        <p class="text-xs text-ink-faint">Pas de données disponibles.</p>
      <% } else { %>
        <% funnelData.forEach(function(f) { %>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs text-ink-muted w-36 text-right truncate flex-shrink-0"><%= f.label %></span>
            <div class="flex-1 bg-surface-raised rounded-full h-2 overflow-hidden">
              <div class="h-2 rounded-full bg-primary/70 transition-all duration-500" style="width: <%= f.pct %>%; min-width: <%= f.value > 0 ? '4px' : '0' %>"></div>
            </div>
            <span class="font-mono text-xs text-ink-muted w-8 text-right flex-shrink-0"><%= f.value %></span>
          </div>
        <% }); %>
      <% } %>
    </div>

    <!-- Raw metrics -->
    <div class="card p-5 mb-6">
      <h2 class="section-title mb-4">Métriques brutes</h2>
      <div class="grid grid-cols-3 gap-3 text-center">
        <% var metrics = [
          { v: latestWeek.posts_published || 0, l: 'Posts publiés' },
          { v: latestWeek.total_reach || 0, l: 'Portée' },
          { v: latestWeek.total_likes || 0, l: 'Likes' },
          { v: latestWeek.total_comments || 0, l: 'Commentaires' },
          { v: latestWeek.info_comments || 0, l: 'Coms INFO' },
          { v: latestWeek.dm_opened || 0, l: 'DM ouverts' },
          { v: latestWeek.calendly_booked || 0, l: 'RDV Calendly' },
          { v: latestWeek.patients_converted || 0, l: 'Convertis' }
        ]; %>
        <% metrics.forEach(function(m) { %>
          <div class="card-raised p-3">
            <div class="font-mono text-lg font-semibold text-ink-primary"><%= m.v %></div>
            <div class="text-xs text-ink-faint mt-0.5"><%= m.l %></div>
          </div>
        <% }); %>
      </div>
      <% if (latestWeek.learnings) { %>
        <div class="mt-4 text-xs text-ink-muted border-t border-border-subtle pt-3">
          <span class="text-ink-faint">Observations ·</span> <%= latestWeek.learnings %>
        </div>
      <% } %>
    </div>

    <!-- Historical table -->
    <% if (previousWeeks.length > 0) { %>
    <div class="card p-5">
      <h2 class="section-title mb-4">Semaines précédentes</h2>
      <div class="overflow-x-auto">
        <table class="table-base">
          <thead>
            <tr>
              <th>Semaine</th><th class="text-right">Portée</th><th class="text-right">Coms</th>
              <th class="text-right">INFO</th><th class="text-right">DM</th>
              <th class="text-right">RDV</th><th class="text-right">Convertis</th>
            </tr>
          </thead>
          <tbody>
            <% previousWeeks.forEach(function(w) { %>
            <tr>
              <td class="font-mono text-xs"><%= w.dates || w.week %></td>
              <td class="text-right font-mono text-xs"><%= w.total_reach || 0 %></td>
              <td class="text-right font-mono text-xs"><%= w.total_comments || 0 %></td>
              <td class="text-right font-mono text-xs"><%= w.info_comments || 0 %></td>
              <td class="text-right font-mono text-xs"><%= w.dm_opened || 0 %></td>
              <td class="text-right font-mono text-xs"><%= w.calendly_booked || 0 %></td>
              <td class="text-right font-mono text-xs"><%= w.patients_converted || 0 %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

  <% } %>
</div>
