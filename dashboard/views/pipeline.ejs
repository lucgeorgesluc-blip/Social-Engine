<div class="max-w-full">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title">Pipeline DM</h1>
      <p class="text-xs text-ink-faint mt-0.5 font-mono"><%= totalProspects %> prospect<%= totalProspects !== 1 ? 's' : '' %> actifs</p>
    </div>
  </div>

  <!-- Funnel summary -->
  <div class="card p-5 mb-6 max-w-xl">
    <h2 class="section-title mb-4">Entonnoir</h2>
    <% funnel.forEach(function(f) { %>
      <div class="flex items-center gap-3 mb-2.5">
        <span class="text-xs text-ink-muted w-28 text-right truncate flex-shrink-0"><%= f.label %></span>
        <div class="flex-1 bg-surface-raised rounded-full h-1.5 overflow-hidden">
          <div class="h-1.5 rounded-full bg-primary/70 transition-all duration-500" style="width: <%= f.pct %>%; min-width: <%= f.count > 0 ? '3px' : '0' %>"></div>
        </div>
        <span class="font-mono text-xs text-ink-muted w-16 text-right flex-shrink-0"><%= f.count %> · <span class="text-ink-faint"><%= f.pct %>%</span></span>
      </div>
    <% }); %>
  </div>

  <!-- Kanban -->
  <div class="overflow-x-auto pb-4">
    <div class="flex gap-3 min-w-max">
      <% DISPLAY_STAGES.forEach(function(stage) { %>
        <% var col = byColumn[stage]; %>
        <div class="kanban-col">
          <!-- Header -->
          <div class="kanban-header">
            <div class="flex items-center gap-2">
              <%
                var dotColor = {
                  INFO: 'bg-amber',
                  CHAUD: 'bg-primary',
                  RDV_PREVU: 'bg-blue-400',
                  CONVERTI: 'bg-success'
                }[stage] || 'bg-ink-faint';
              %>
              <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 <%= dotColor %>"></span>
              <h3 class="text-sm font-semibold text-ink-primary"><%= DISPLAY_LABELS[stage] %></h3>
            </div>
            <span class="font-mono text-xs text-ink-faint bg-surface-base px-2 py-0.5 rounded-full"><%= col.length %></span>
          </div>
          <!-- Cards -->
          <div class="kanban-body">
            <% if (col.length === 0) { %>
              <div class="text-xs text-ink-faint text-center py-8">Vide</div>
            <% } else { %>
              <% col.forEach(function(p) { %>
                <div class="kanban-card <%= p.isOverdue ? 'overdue' : '' %>">
                  <div class="text-sm font-medium text-ink-primary truncate"><%= p.prospect_name || p.full_name || 'Inconnu' %></div>
                  <div class="font-mono text-xs text-ink-faint mt-1">
                    <%= p.date_first_contact ? new Date(p.date_first_contact).toLocaleDateString('fr-FR') : '—' %>
                  </div>
                  <% if (p.notes) { %>
                    <div class="text-xs text-ink-muted mt-1.5 line-clamp-2"><%= p.notes %></div>
                  <% } %>
                  <% if (p.calendly_date && (stage === 'RDV_PREVU' || stage === 'CONVERTI')) { %>
                    <div class="font-mono text-xs text-amber mt-1.5">
                      RDV <%= new Date(p.calendly_date).toLocaleDateString('fr-FR') %>
                    </div>
                  <% } %>
                  <% if (p.isOverdue) { %>
                    <div class="text-xs text-danger mt-1.5 font-medium">En retard · <span class="font-mono"><%= p.hoursSince %>h</span></div>
                  <% } %>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <% if (totalProspects === 0) { %>
    <div class="card p-8 text-sm text-ink-faint text-center mt-4">
      Aucun prospect dans le pipeline
    </div>
  <% } %>
</div>
