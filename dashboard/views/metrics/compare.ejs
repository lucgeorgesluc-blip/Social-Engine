<div class="max-w-5xl">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <a href="/stats" class="text-sm text-gray-400 hover:text-secondary">← Statistiques</a>
      <span class="text-gray-300">/</span>
      <h1 class="text-lg font-semibold text-secondary">Comparaison des performances</h1>
    </div>
    <a href="/metrics/input" class="text-sm text-primary hover:underline">Saisir métriques →</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Post</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Type</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Date</th>
          <th class="text-right px-4 py-3 font-medium text-gray-600">Portée</th>
          <th class="text-right px-4 py-3 font-medium text-gray-600">Likes</th>
          <th class="text-right px-4 py-3 font-medium text-gray-600">Commentaires</th>
          <th class="text-right px-4 py-3 font-medium text-gray-600">Partages</th>
          <th class="text-right px-4 py-3 font-medium text-gray-600">Engagement %</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% posts.forEach(function(post) { %>
        <tr class="hover:bg-gray-50/50">
          <td class="px-4 py-3 text-secondary font-medium truncate max-w-xs"><%= post.hook || post.id %></td>
          <td class="px-4 py-3">
            <% if (post.type) { %>
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded"><%= post.type %></span>
            <% } else { %><span class="text-gray-300">—</span><% } %>
          </td>
          <td class="px-4 py-3 text-xs text-gray-500">
            <%= post.published_date ? new Date(post.published_date).toLocaleDateString('fr-FR') : '—' %>
          </td>
          <td class="px-4 py-3 text-right font-medium text-secondary"><%= post.reach %></td>
          <td class="px-4 py-3 text-right"><%= post.likes %></td>
          <td class="px-4 py-3 text-right"><%= post.comments_count %></td>
          <td class="px-4 py-3 text-right"><%= post.shares %></td>
          <td class="px-4 py-3 text-right font-semibold text-primary"><%= post.engagement_rate %>%</td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% if (posts.length === 0) { %>
      <p class="text-center text-gray-400 py-8 text-sm">Aucun post publié avec des métriques.</p>
    <% } %>
  </div>
</div>
