<div class="max-w-2xl">
  <h1 class="page-title mb-6">Génération IA</h1>

  <!-- Usage meter -->
  <% var usagePct = Math.round((usage.count / usage.limit) * 100);
     var usageState = usage.count >= usage.limit ? 'danger' : usage.count >= usage.warning ? 'amber' : 'success'; %>
  <div class="card p-4 mb-5 flex items-center justify-between gap-4">
    <div class="text-sm text-ink-muted">
      <span class="font-mono text-ink-primary font-semibold"><%= usage.count %></span>
      <span class="text-ink-faint"> / <%= usage.limit %></span>
      <span class="ml-1">générations ce mois</span>
      <% if (usage.count >= usage.limit) { %><span class="ml-1 text-danger text-xs">— Limite atteinte</span><% } %>
      <% if (usage.count >= usage.warning && usage.count < usage.limit) { %><span class="ml-1 text-amber text-xs">— Approche limite</span><% } %>
    </div>
    <div class="w-28 h-1.5 bg-surface-raised rounded-full overflow-hidden flex-shrink-0">
      <div class="h-1.5 rounded-full transition-all duration-500
        <%= usageState === 'danger' ? 'bg-danger' : usageState === 'amber' ? 'bg-amber' : 'bg-success' %>"
        style="width: <%= usagePct %>%"></div>
    </div>
  </div>

  <!-- Suggestions -->
  <% if (suggestions && suggestions.length > 0) { %>
  <div class="card p-4 mb-5 border-border-muted">
    <h3 class="section-title mb-3">Suggestions basées sur les commentaires</h3>
    <ul class="space-y-2">
      <% suggestions.forEach(function(s) { %>
      <li class="flex items-center justify-between text-sm">
        <span class="text-ink-muted">«&nbsp;<%= s.objection_type %>&nbsp;» <span class="font-mono text-xs text-ink-faint ml-1"><%= s.frequency %>×</span></span>
        <a href="/dashboard/ai?type=objection-buster&context=<%= encodeURIComponent(s.objection_type) %>"
           class="btn-ghost text-xs">Générer →</a>
      </li>
      <% }); %>
    </ul>
  </div>
  <% } %>

  <!-- Error -->
  <% if (error) { %>
    <div class="card p-4 mb-5 border-danger/30 text-danger-light text-sm"><%= error %></div>
  <% } %>

  <!-- Generation form -->
  <div class="card p-6 mb-5">
    <h2 class="section-title mb-4">Nouveau post</h2>
    <form method="POST" action="/dashboard/ai/generate" class="space-y-4">
      <div>
        <label class="block text-xs font-medium text-ink-muted mb-1.5">Type de post</label>
        <select name="type" id="post-type-select" class="input" required>
          <% postTypes.forEach(function(pt) { %>
            <option value="<%= pt.id %>" <%= selectedType === pt.id ? 'selected' : '' %>
              data-needs-context="<%= pt.needsContext %>" data-context-label="<%= pt.contextLabel %>">
              <%= pt.label %>
            </option>
          <% }); %>
        </select>
      </div>
      <div id="context-group" class="<%= !selectedType || postTypes.find(function(p){return p.id===selectedType;}).needsContext ? '' : 'hidden' %>">
        <label id="context-label" class="block text-xs font-medium text-ink-muted mb-1.5">
          <%= selectedType && postTypes.find(function(p){return p.id===selectedType;}) ? postTypes.find(function(p){return p.id===selectedType;}).contextLabel || 'Contexte' : 'Contexte' %>
        </label>
        <textarea name="context" id="context-input" rows="2" class="input resize-none" placeholder="Précisez le contexte..."><%= context %></textarea>
      </div>
      <button type="submit" <%= usage.count >= usage.limit ? 'disabled' : '' %> class="btn-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Générer
      </button>
    </form>
  </div>

  <!-- Generated output -->
  <% if (generated) { %>
  <div class="card p-6">
    <h2 class="section-title mb-4">Post généré — modifiez puis sauvegardez</h2>
    <form method="POST" action="/posts" class="space-y-4">
      <textarea name="content" rows="12" class="input resize-y font-mono text-xs leading-relaxed"><%= generated %></textarea>
      <input type="hidden" name="type" value="<%= selectedType || '' %>">
      <input type="hidden" name="status" value="draft">
      <input type="hidden" name="platform" value="facebook">
      <div class="flex items-center gap-3">
        <button type="submit" class="btn-secondary">Sauvegarder brouillon</button>
        <button type="button" id="copy-generated-btn" class="btn-ghost">Copier</button>
      </div>
    </form>
  </div>
  <script>
    document.getElementById('copy-generated-btn').addEventListener('click', function() {
      var text = document.querySelector('textarea[name="content"]').value;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(text).then(function() {
          var btn = document.getElementById('copy-generated-btn');
          btn.textContent = 'Copié ✓';
          setTimeout(function() { btn.textContent = 'Copier'; }, 2000);
        });
      }
    });
  </script>
  <% } %>
</div>

<script>
(function() {
  var typeSelect = document.getElementById('post-type-select');
  var contextGroup = document.getElementById('context-group');
  var contextLabel = document.getElementById('context-label');
  var postTypes = <%- JSON.stringify(postTypes) %>;
  function updateContext() {
    var pt = postTypes.find(function(p) { return p.id === typeSelect.value; });
    if (pt && pt.needsContext) {
      contextGroup.classList.remove('hidden');
      if (pt.contextLabel) contextLabel.textContent = pt.contextLabel;
    } else {
      contextGroup.classList.add('hidden');
    }
  }
  typeSelect.addEventListener('change', updateContext);
  updateContext();
})();
</script>
