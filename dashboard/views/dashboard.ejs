<!-- Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="page-title">Bonjour, Benjamin</h1>
    <p class="text-xs text-ink-faint mt-0.5 font-mono"><%= new Date().toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long'}) %></p>
  </div>
  <!-- DB status -->
  <div class="flex items-center gap-1.5 text-xs text-ink-muted">
    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 <%= dbError ? 'bg-danger' : 'bg-success' %>"></span>
    <%= dbError ? 'DB hors ligne' : 'DB connectée' %>
  </div>
</div>

<!-- KPI row -->
<div class="grid grid-cols-3 gap-3 mb-8">
  <div class="card p-4 text-center">
    <div class="font-mono text-2xl font-semibold text-ink-primary"><%= counts.posts %></div>
    <div class="text-xs text-ink-faint mt-0.5">Posts</div>
  </div>
  <div class="card p-4 text-center">
    <div class="font-mono text-2xl font-semibold text-ink-primary"><%= counts.comments %></div>
    <div class="text-xs text-ink-faint mt-0.5">Commentaires</div>
  </div>
  <div class="card p-4 text-center">
    <div class="font-mono text-2xl font-semibold text-ink-primary"><%= counts.prospects %></div>
    <div class="text-xs text-ink-faint mt-0.5">Prospects</div>
  </div>
</div>

<% if (dbError) { %>
  <div class="mb-6 card p-4 border-danger/30 text-danger-light text-sm">
    Impossible de charger les données. Vérifiez la connexion à la base de données.
  </div>
<% } %>

<!-- Posts du jour -->
<section class="mb-8">
  <div class="flex items-center justify-between mb-3">
    <h2 class="section-title">
      Posts du jour
      <span class="ml-1.5 font-mono text-xs text-ink-faint font-normal"><%= todayPostsTotal %></span>
    </h2>
    <% if (todayPostsTotal > 0) { %>
      <a href="/posts" class="btn-ghost text-xs">Voir tout →</a>
    <% } %>
  </div>
  <% if (todayPosts.length === 0) { %>
    <div class="card p-4 text-sm text-ink-faint">Aucun post prévu aujourd'hui</div>
  <% } else { %>
    <div class="space-y-2">
      <% todayPosts.forEach(function(post) { %>
        <div class="card p-4 flex items-center justify-between gap-3">
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium text-ink-primary truncate"><%= post.hook || 'Sans titre' %></div>
            <div class="text-xs text-ink-faint mt-0.5"><%= post.platform %><% if (post.type) { %> · <%= post.type %><% } %></div>
          </div>
          <span class="badge badge-<%= post.status %>"><%= post.status %></span>
        </div>
      <% }); %>
    </div>
  <% } %>
</section>

<!-- Commentaires en attente -->
<section class="mb-8">
  <div class="flex items-center justify-between mb-3">
    <h2 class="section-title">
      Commentaires
      <span class="ml-1.5 font-mono text-xs text-ink-faint font-normal"><%= pendingCommentsTotal %></span>
      <% if (overdueCommentCount > 0) { %>
        <span class="ml-2 text-xs text-danger font-normal">— <%= overdueCommentCount %> en retard</span>
      <% } %>
    </h2>
    <% if (pendingCommentsTotal > 0) { %>
      <a href="/comments" class="btn-ghost text-xs">Voir tout →</a>
    <% } %>
  </div>
  <% if (pendingComments.length === 0) { %>
    <div class="card p-4 text-sm text-ink-faint">Aucun commentaire en attente</div>
  <% } else { %>
    <div class="space-y-2">
      <% pendingComments.forEach(function(c) { %>
        <div class="card p-4 <%= c.isOverdue ? 'overdue' : '' %>">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-ink-primary"><%= c.author_name || 'Anonyme' %></div>
              <div class="text-xs text-ink-faint mt-0.5">sur « <%= c.post_hook || 'Post inconnu' %> »</div>
              <div class="text-sm text-ink-muted mt-1.5 line-clamp-2"><%= c.comment_text %></div>
            </div>
            <% if (c.isOverdue) { %>
              <span class="text-xs text-danger font-mono flex-shrink-0">+2h</span>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</section>

<!-- Suivis DM -->
<section>
  <div class="flex items-center justify-between mb-3">
    <h2 class="section-title">
      Suivis DM
      <span class="ml-1.5 font-mono text-xs text-ink-faint font-normal"><%= activeProspectsTotal %></span>
      <% if (overdueProspectCount > 0) { %>
        <span class="ml-2 text-xs text-danger font-normal">— <%= overdueProspectCount %> en retard</span>
      <% } %>
    </h2>
    <% if (activeProspectsTotal > 0) { %>
      <a href="/pipeline" class="btn-ghost text-xs">Voir tout →</a>
    <% } %>
  </div>
  <% if (activeProspects.length === 0) { %>
    <div class="card p-4 text-sm text-ink-faint">Aucun suivi DM</div>
  <% } else { %>
    <div class="space-y-2">
      <% activeProspects.forEach(function(p) { %>
        <div class="card p-4 flex items-center justify-between gap-3 <%= p.isOverdue ? 'overdue' : '' %>">
          <div>
            <div class="text-sm font-medium text-ink-primary"><%= p.prospect_name || p.full_name || 'Inconnu' %></div>
            <div class="text-xs text-ink-faint mt-0.5 font-mono">
              <%= p.stage %> · <%= p.date_first_contact ? new Date(p.date_first_contact).toLocaleDateString('fr-FR') : '—' %>
            </div>
          </div>
          <% if (p.isOverdue) { %>
            <span class="text-xs text-danger font-medium flex-shrink-0">En retard</span>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>
</section>
