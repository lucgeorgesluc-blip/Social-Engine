<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion — Social Dashboard</title>
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen flex items-center justify-center bg-surface-base">

  <!-- Subtle background texture -->
  <div class="fixed inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(220,81,44,0.05) 0%, transparent 70%);" aria-hidden="true"></div>

  <div class="relative w-full max-w-sm px-4">
    <!-- Brand -->
    <div class="text-center mb-8">
      <h1 class="font-serif text-2xl font-semibold text-ink-primary">Corinne Lacoste</h1>
      <p class="text-xs text-ink-faint mt-1 font-mono tracking-widest uppercase">Social Dashboard</p>
    </div>

    <!-- Card -->
    <div class="card p-8">
      <form method="POST" action="/login" class="space-y-4">
        <div>
          <label for="password" class="block text-xs font-medium text-ink-muted mb-1.5">Mot de passe</label>
          <input
            id="password"
            type="password"
            name="password"
            placeholder="••••••••"
            required
            autocomplete="current-password"
            class="input"
          >
          <% if (error) { %>
            <p class="text-danger-light text-xs mt-2 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
              <%= error %>
            </p>
          <% } %>
        </div>
        <button type="submit" class="btn-primary w-full justify-center">
          Se connecter
        </button>
      </form>
    </div>

    <p class="text-center text-ink-faint text-xs mt-6">magnetiseuse-lacoste-corinne.fr</p>
  </div>
</body>
</html>
