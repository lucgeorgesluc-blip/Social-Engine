<div class="max-w-4xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title">Commentaires</h1>
      <p class="text-xs text-ink-faint mt-0.5 font-mono">
        <%= totalCount %> total · <%= pendingCount %> en attente<% if (overdueCount > 0) { %> · <span class="text-danger"><%= overdueCount %> en retard</span><% } %>
      </p>
    </div>
  </div>

  <div class="space-y-3">
    <% Object.keys(byPost).forEach(function(postId, idx) { %>
      <% var group = byPost[postId]; %>
      <div class="card overflow-hidden">

        <!-- Accordion header -->
        <button type="button"
                data-accordion="<%= idx %>"
                class="w-full flex items-center justify-between px-4 py-3.5 bg-surface-raised hover:bg-surface-hover text-left transition-colors duration-150">
          <div class="flex-1 min-w-0 pr-4">
            <div class="text-sm font-medium text-ink-primary truncate"><%= group.post_hook %></div>
            <div class="font-mono text-xs text-ink-faint mt-0.5">
              <%= group.comments.length %> commentaire<%= group.comments.length > 1 ? 's' : '' %>
              <% if (group.pendingCount > 0) { %> · <span class="text-ink-muted"><%= group.pendingCount %> en attente</span><% } %>
              <% if (group.overdueCount > 0) { %> · <span class="text-danger"><%= group.overdueCount %> en retard</span><% } %>
            </div>
          </div>
          <svg data-accordion-icon class="w-4 h-4 text-ink-faint flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <!-- Accordion body -->
        <div id="accordion-body-<%= idx %>" class="divide-y divide-border-subtle/50">
          <% group.comments.forEach(function(c) { %>
            <%
              var dotColor = { grey: 'bg-ink-faint', orange: 'bg-amber', green: 'bg-success' }[c.dotState] || 'bg-ink-faint';
              var badgeClass = {
                info: 'badge-info',
                objection: 'badge-objection',
                positive: 'badge-positive'
              }[c.classification] || 'badge-draft';
            %>
            <div class="px-4 py-3.5 <%= c.isOverdue ? 'overdue' : '' %>">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class="w-2 h-2 rounded-full flex-shrink-0 <%= dotColor %>"></span>
                    <span class="text-sm font-medium text-ink-primary"><%= c.author_name || 'Anonyme' %></span>
                    <span class="font-mono text-xs text-ink-faint"><%= c.date ? new Date(c.date).toLocaleDateString('fr-FR') : '' %></span>
                  </div>
                  <div class="text-sm text-ink-muted ml-4 leading-relaxed"><%= c.comment_text %></div>
                </div>
                <span class="badge <%= badgeClass %> flex-shrink-0 mt-0.5"><%= c.classification || 'non classé' %></span>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% }); %>

    <% if (Object.keys(byPost).length === 0) { %>
      <div class="card p-10 text-sm text-ink-faint text-center">Aucun commentaire</div>
    <% } %>
  </div>

  <script src="/js/dashboard.js" defer></script>
</div>
