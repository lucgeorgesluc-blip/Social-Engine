<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion — Social Dashboard</title>
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="bg-white rounded-xl shadow-md p-8 w-full max-w-sm">
    <h1 class="text-2xl font-bold text-secondary text-center">Social Dashboard</h1>
    <p class="text-xs font-medium text-gray-500 text-center mt-1">Corinne Lacoste</p>

    <form method="POST" action="/login" class="mt-8 space-y-4">
      <div>
        <input
          type="password"
          name="password"
          placeholder="Mot de passe"
          required
          class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
        >
        <% if (error) { %>
          <p class="text-red-600 text-xs mt-2"><%= error %></p>
        <% } %>
      </div>
      <button
        type="submit"
        class="w-full py-3 bg-primary text-white rounded-lg font-semibold text-sm hover:bg-opacity-90 transition"
      >Se connecter</button>
    </form>
  </div>
</body>
</html>
