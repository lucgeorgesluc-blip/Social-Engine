<div class="max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <a href="/posts" class="text-sm text-ink-muted hover:text-ink-base transition-colors">← Posts</a>
    <span class="text-border-subtle">/</span>
    <h1 class="text-lg font-semibold text-ink-base">Nouveau post</h1>
  </div>

  <form method="POST" action="/posts" class="card p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-ink-base mb-1">Accroche <span class="text-ink-muted font-normal">(titre court)</span></label>
      <input type="text" name="hook" placeholder="Ex: 3 signes que vous avez besoin d'une séance..." class="input">
    </div>

    <div>
      <label class="block text-sm font-medium text-ink-base mb-1">Contenu <span class="text-danger">*</span></label>
      <textarea name="content" rows="6" required placeholder="Rédigez votre post Facebook..." class="input resize-y"></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-ink-base mb-1">Type</label>
        <select name="type" class="input">
          <option value="">— Choisir —</option>
          <option value="objection-buster">Objection buster</option>
          <option value="temoignage">Témoignage</option>
          <option value="myth-buster">Myth buster</option>
          <option value="timeline">Timeline</option>
          <option value="tips">Tips</option>
          <option value="education">Éducation</option>
          <option value="promotion">Promotion</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-ink-base mb-1">Plateforme <span class="text-danger">*</span></label>
        <select name="platform" required class="input">
          <option value="">— Choisir —</option>
          <option value="facebook">Facebook</option>
          <option value="both">Facebook + Instagram</option>
        </select>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-ink-base mb-1">Date prévue</label>
      <input type="date" name="scheduled_date" class="input">
    </div>

    <div class="flex items-center gap-4 pt-2">
      <button type="submit" class="btn-primary">Créer le post</button>
      <a href="/posts" class="btn-ghost text-sm">Annuler</a>
    </div>
  </form>
</div>
