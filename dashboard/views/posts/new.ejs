<div class="max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <a href="/posts" class="text-sm text-gray-400 hover:text-secondary">← Posts</a>
    <span class="text-gray-300">/</span>
    <h1 class="text-lg font-semibold text-secondary">Nouveau post</h1>
  </div>

  <form method="POST" action="/posts" class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-secondary mb-1">Accroche <span class="text-gray-400 font-normal">(titre court)</span></label>
      <input type="text" name="hook" placeholder="Ex: 3 signes que vous avez besoin d'une séance..." class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-secondary">
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1">Contenu <span class="text-red-400">*</span></label>
      <textarea name="content" rows="6" required placeholder="Rédigez votre post Facebook..." class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-secondary resize-y"></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-secondary mb-1">Type</label>
        <select name="type" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-secondary">
          <option value="">— Choisir —</option>
          <option value="objection-buster">Objection buster</option>
          <option value="temoignage">Témoignage</option>
          <option value="myth-buster">Myth buster</option>
          <option value="timeline">Timeline</option>
          <option value="tips">Tips</option>
          <option value="education">Éducation</option>
          <option value="promotion">Promotion</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-secondary mb-1">Plateforme <span class="text-red-400">*</span></label>
        <select name="platform" required class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-secondary">
          <option value="">— Choisir —</option>
          <option value="facebook">Facebook</option>
          <option value="both">Facebook + Instagram</option>
        </select>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1">Date prévue</label>
      <input type="date" name="scheduled_date" class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-secondary">
    </div>

    <div class="flex items-center gap-4 pt-2">
      <button type="submit" class="bg-primary text-white px-6 py-3 rounded-full hover:bg-opacity-90 transition font-medium text-sm">Créer le post</button>
      <a href="/posts" class="text-sm text-gray-500 hover:text-secondary">Annuler</a>
    </div>
  </form>
</div>
