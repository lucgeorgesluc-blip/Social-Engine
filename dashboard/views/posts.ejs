<div class="max-w-5xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="page-title">Posts</h1>
    <a href="/posts/new" class="btn-primary">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      Nouveau
    </a>
  </div>

  <!-- View tabs -->
  <div class="flex items-center gap-4 mb-5 border-b border-border-subtle">
    <a href="/posts" class="text-sm font-medium pb-2.5 -mb-px <%= !filterStatus || !currentPath || currentPath === '/posts' ? 'text-ink-primary border-b-2 border-primary' : 'text-ink-muted hover:text-ink-primary' %>">Liste</a>
    <a href="/posts/calendar" class="text-sm font-medium pb-2.5 -mb-px text-ink-muted hover:text-ink-primary transition-colors">Calendrier</a>
  </div>

  <!-- Status filters -->
  <div class="flex gap-2 flex-wrap mb-5">
    <%
      var filters = [
        { href: '/posts', label: 'Tous', count: totalCount, key: null },
        { href: '/posts?status=draft', label: 'Brouillons', count: statusCounts.draft, key: 'draft' },
        { href: '/posts?status=scheduled', label: 'Programmés', count: statusCounts.scheduled, key: 'scheduled' },
        { href: '/posts?status=published', label: 'Publiés', count: statusCounts.published, key: 'published' }
      ];
    %>
    <% filters.forEach(function(f) { %>
      <% var isActive = f.key ? filterStatus === f.key : !filterStatus; %>
      <a href="<%= f.href %>" class="px-3 py-1.5 rounded-full text-xs font-medium transition-all duration-150 <%= isActive ? 'bg-primary text-white' : 'bg-surface-raised border border-border-subtle text-ink-muted hover:text-ink-primary hover:border-border-muted' %>">
        <%= f.label %> <span class="font-mono <%= isActive ? 'text-white/70' : 'text-ink-faint' %>"><%= f.count %></span>
      </a>
    <% }); %>
  </div>

  <!-- Table -->
  <div class="card overflow-hidden">
    <table class="table-base">
      <thead>
        <tr>
          <th class="w-28">Date</th>
          <th>Titre</th>
          <th class="w-28">Statut</th>
          <th class="text-right w-32">Commentaires</th>
        </tr>
      </thead>
      <tbody>
        <% if (posts.length === 0) { %>
          <tr><td colspan="4" class="px-4 py-10 text-center text-ink-faint">Aucun post trouvé</td></tr>
        <% } else { %>
          <% posts.forEach(function(post) { %>
            <tr>
              <td class="font-mono text-xs text-ink-faint">
                <%= post.published_date ? new Date(post.published_date).toLocaleDateString('fr-FR') : '—' %>
              </td>
              <td class="text-ink-primary font-medium text-sm">
                <% if (post.status === 'draft') { %>
                  <a href="/dashboard/ai?post_id=<%= post.id %>&type=<%= encodeURIComponent(post.type || '') %>&context=<%= encodeURIComponent(post.hook || '') %>" class="hover:text-primary transition-colors"><%= post.hook || 'Sans titre' %></a>
                <% } else { %>
                  <a href="/posts/<%= post.id %>/edit" class="hover:text-primary transition-colors"><%= post.hook || 'Sans titre' %></a>
                <% } %>
              </td>
              <td><span class="badge badge-<%= post.status %>"><%= post.status %></span></td>
              <td class="text-right font-mono text-sm text-ink-muted"><%= post.comment_count %></td>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
