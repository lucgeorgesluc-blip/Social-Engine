<div class="max-w-5xl">
  <h1 class="text-lg font-semibold text-secondary">Calendrier</h1>

  <div class="mt-4 flex items-center gap-3">
    <a href="/posts" class="text-sm font-medium text-gray-400 hover:text-gray-600 pb-1">Liste</a>
    <a href="/posts/calendar" class="text-sm font-medium text-primary border-b-2 border-primary pb-1">Calendrier</a>
  </div>

  <!-- Month navigation -->
  <div class="mt-4 flex items-center justify-between">
    <span class="text-sm font-medium text-secondary capitalize"><%= monthLabel %></span>
    <div class="flex items-center gap-2">
      <a href="/posts/calendar?date=<%= prevDateStr %>" class="px-2 py-1 rounded bg-gray-100 text-gray-600 text-xs hover:bg-gray-200">&larr;</a>
      <a href="/posts/calendar?date=<%= nextDateStr %>" class="px-2 py-1 rounded bg-gray-100 text-gray-600 text-xs hover:bg-gray-200">&rarr;</a>
    </div>
  </div>

  <!-- Monthly grid only — no week toggle (CONTEXT D-03) -->
  <div class="mt-4 grid grid-cols-7 gap-1">
    <% ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'].forEach(function(d) { %>
      <div class="text-center text-xs font-medium text-gray-500 py-1"><%= d %></div>
    <% }); %>

    <% days.forEach(function(day) { %>
      <% var todayKey = new Date().toISOString().split('T')[0]; %>
      <% var isToday = day.key === todayKey; %>
      <% var cellPosts = postsByDate[day.key] || []; %>
      <button type="button"
              data-day-key="<%= day.key %>"
              class="text-left min-h-20 bg-white rounded-lg p-2 border <%= isToday ? 'border-primary' : 'border-gray-100' %> <%= day.inMonth ? '' : 'opacity-40' %> hover:border-primary cursor-pointer">
        <div class="text-xs font-medium <%= isToday ? 'text-primary' : 'text-gray-500' %> mb-1"><%= day.dayNum %></div>
        <% cellPosts.slice(0,3).forEach(function(post) { %>
          <% var dotColor = { draft:'bg-gray-400', scheduled:'bg-blue-500', published:'bg-green-500' }[post.status] || 'bg-gray-400'; %>
          <div class="text-xs flex items-center gap-1 mb-0.5 truncate">
            <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 <%= dotColor %>"></span>
            <span class="truncate"><%= post.hook ? post.hook.substring(0,18) : '—' %></span>
          </div>
        <% }); %>
        <% if (cellPosts.length > 3) { %>
          <div class="text-xs text-gray-400">+<%= cellPosts.length - 3 %></div>
        <% } %>
      </button>
    <% }); %>
  </div>

  <!-- Click-to-expand day panel (filled by JS) -->
  <div id="day-expand-panel" class="mt-4 hidden bg-white rounded-xl border border-gray-100 p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 id="day-expand-title" class="text-sm font-semibold text-secondary"></h2>
      <button type="button" id="day-expand-close" class="text-xs text-gray-400 hover:text-gray-600">Fermer &#x2715;</button>
    </div>
    <div id="day-expand-list" class="space-y-2"></div>
  </div>

  <!-- Inline data for JS — posts keyed by date string -->
  <script id="calendar-data" type="application/json"><%- JSON.stringify(postsByDate) %></script>
</div>
