<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Social Dashboard — Corinne Lacoste</title>
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="bg-gray-50 min-h-screen font-sans">

  <!-- Mobile hamburger button (visible below md breakpoint only) -->
  <button
    id="menu-toggle"
    class="fixed top-3 left-3 z-40 md:hidden w-11 h-11 flex items-center justify-center bg-secondary text-white rounded-lg shadow-lg"
    aria-label="Menu"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <!-- Sidebar overlay for mobile -->
  <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-20 hidden md:hidden"></div>

  <!-- Sidebar -->
  <aside
    id="sidebar"
    class="fixed inset-y-0 left-0 w-60 bg-secondary text-white transform -translate-x-full md:translate-x-0 transition-transform duration-200 z-30 flex flex-col"
  >
    <!-- Sidebar header -->
    <div class="px-6 py-5">
      <div class="text-sm font-semibold text-white">Social Dashboard</div>
      <div class="text-xs text-white/70 mt-0.5">Corinne Lacoste</div>
    </div>

    <!-- Nav items -->
    <nav class="flex-1 px-3 py-4 space-y-1">
      <a href="/" class="flex items-center px-3 py-2.5 rounded-lg text-white bg-white/10 border-l-4 border-primary text-sm font-medium">
        Accueil
      </a>
      <a href="/posts" class="flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition <%= typeof currentPath !== 'undefined' && (currentPath === '/posts' || currentPath === '/posts/calendar') ? 'text-white bg-white/10 border-l-4 border-primary' : 'text-white/70 hover:text-white hover:bg-white/5' %>">
        Posts
      </a>
      <a href="/comments" class="flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition <%= typeof currentPath !== 'undefined' && currentPath === '/comments' ? 'text-white bg-white/10 border-l-4 border-primary' : 'text-white/70 hover:text-white hover:bg-white/5' %>">
        Commentaires
      </a>
      <a href="/pipeline" class="flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition <%= typeof currentPath !== 'undefined' && currentPath === '/pipeline' ? 'text-white bg-white/10 border-l-4 border-primary' : 'text-white/70 hover:text-white hover:bg-white/5' %>">
        Pipeline
      </a>
      <a href="/stats" class="flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition <%= typeof currentPath !== 'undefined' && currentPath === '/stats' ? 'text-white bg-white/10 border-l-4 border-primary' : 'text-white/70 hover:text-white hover:bg-white/5' %>">
        Statistiques
      </a>
    </nav>

    <!-- Logout at bottom -->
    <div class="px-3 py-4 border-t border-white/10">
      <form method="POST" action="/logout">
        <button type="submit" class="w-full text-left px-3 py-2.5 text-white/70 hover:text-white text-sm transition">
          Se déconnecter
        </button>
      </form>
    </div>
  </aside>

  <!-- Main content -->
  <main class="md:ml-60 min-h-screen p-6">
    <%- body %>
  </main>

  <script src="/js/app.js"></script>
</body>
</html>
